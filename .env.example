DATABASE_URL="postgres://postgres:postgres@localhost:5432/clearwater"
# Vercel Postgres-compatible alternatives. ClearWater checks these after DATABASE_URL.
POSTGRES_URL=""
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""
AUTH_SECRET="replace-with-a-generated-secret"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Keep as "mock" until database queries are intentionally enabled.
CLEARWATER_DATA_SOURCE="mock"

# Optional deployment/runtime placeholders.
# Set to "true" on hosted environments that need Auth.js to trust proxy headers.
AUTH_TRUST_HOST="true"

# Planned integrations. Leave empty until each integration is implemented.
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
STRIPE_SECRET_KEY=""
SMS_PROVIDER_API_KEY=""
EMAIL_PROVIDER_API_KEY=""
GRAPHHOPPER_API_KEY=""
LAMOTTE_SPINTOUCH_CLIENT_ID=""
